# ============================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como .env.local para desarrollo local
# cp .env.example .env.local

# ============================================
# API BACKEND
# ============================================
# Para desarrollo local: http://localhost:8787
# Para producción: https://api.motaxi.dev
# NEXT_PUBLIC_API_URL es para el cliente (browser)
# API_BACKEND_URL es para llamadas server-side (webhooks, API routes de Next.js)
# API_URL es para React Native/Expo
NEXT_PUBLIC_API_URL=http://localhost:8787
API_BACKEND_URL=http://localhost:8787
API_URL=http://localhost:8787

# ============================================
# GOOGLE MAPS API
# ============================================
# Obtén tu API key en: https://console.cloud.google.com/
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY es para Next.js/Web
# GOOGLE_MAPS_API_KEY_ANDROID y GOOGLE_MAPS_API_KEY_IOS son para React Native
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY_ANDROID=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY_IOS=your_google_maps_api_key_here

# ============================================
# CLERK AUTHENTICATION (OPCIONAL)
# ============================================
# Si decides usar Clerk en lugar de autenticación personalizada
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
# CLERK_SECRET_KEY=your_clerk_secret_key
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# EPAYCO (PAGOS Y SUSCRIPCIONES)
# ============================================
# Obtén tus credenciales en: https://epayco.com/
# NEXT_PUBLIC_EPAYCO_PUBLIC_KEY es la llave pública del comercio
# EPAYCO_TEST_MODE=true para pruebas, false para producción
# NEXT_PUBLIC_SITE_URL es la URL pública del sitio (para callbacks)
NEXT_PUBLIC_EPAYCO_PUBLIC_KEY=your_epayco_public_key_here
EPAYCO_TEST_MODE=true
NEXT_PUBLIC_SITE_URL=https://motaxi.dev
